import 'package:encrocante_app/models/platillo_model.dart';

// Este modelo nos ayuda a agrupar un Platillo con su cantidad.
class CartItem {
  final Platillo platillo;
  int cantidad;
  String? notas; // Nuevo campo para notas

  CartItem({required this.platillo, this.cantidad = 1, this.notas});

  // copyWith para crear una copia actualizada del objeto de forma inmutable
  CartItem copyWith({
    Platillo? platillo,
    int? cantidad,
    String? notas,
  }) {
    return CartItem(
      platillo: platillo ?? this.platillo,
      cantidad: cantidad ?? this.cantidad,
      notas: notas ?? this.notas,
    );
  }

  void incrementar() {
    cantidad++;
  }

  void decrementar() {
    if (cantidad > 0) {
      cantidad--;
    }
  }

  double get subtotal => platillo.precio * cantidad;
}
